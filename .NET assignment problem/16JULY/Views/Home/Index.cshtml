@model _16_jul2.Models.EmployeeDepartmentViewModel

@{
    ViewData["Title"] = "Employee & Department";
}

<h1 style="text-align:center; color:#0d6efd; margin:25px 0; font-family:Arial;">
    Welcome to the System
</h1>

<div style="width:90%; margin:auto;">

    <!-- Employee Card -->
    <div style="background-color:white; border-radius:15px; padding:20px; margin-bottom:35px; box-shadow:0px 4px 12px rgba(0,0,0,0.3);">

        <h2 style="text-align:center; color:#7C3AED;">Employee Details</h2>

        <table style="width:100%; border-collapse:collapse; text-align:center;" border="1" cellpadding="10">

            <thead>
                <tr style="background-color:#0d6efd; color:white;">
                    <th>Employee ID</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Email</th>
                    <th>Salary</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Employees)
                {
                    <tr>
                        <td>@item.EmployeeId</td>
                        <td>@item.Name</td>
                        <td>@item.Department</td>
                        <td>@item.Email</td>
                        <td>₹ @item.Salary</td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

    <!-- Department Card -->
    <div style="background-color:white; border-radius:15px; padding:20px; box-shadow:0px 4px 12px rgba(0,0,0,0.3);">

        <h2 style="text-align:center; color:#7C3AED;">Department Details</h2>

        <table style="width:100%; border-collapse:collapse; text-align:center;" border="1" cellpadding="10">

            <thead>
                <tr style="background-color:#0d6efd; color:white;">
                    <th>Department Name</th>
                    <th>Department Head</th>
                    <th>Head Contact</th>
                    <th>Head Email</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Departments)
                {
                    <tr>
                        <td>@item.DeptName</td>
                        <td>@item.DepartmentHead</td>
                        <td>@item.HeadContact</td>
                        <td>@item.HeadEmail</td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>