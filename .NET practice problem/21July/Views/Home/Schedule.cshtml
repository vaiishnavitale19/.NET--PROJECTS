@model List<_21Jul.Models.Course>

@{
    ViewData["Title"] = "Registration Success";
}

<h3 style="text-align:center; color:green;">Register Successfully</h3>

<h4 style="text-align:center;">
    Welcome, @TempData["StudentName"]
</h4>

<p style="text-align:center;">
    Your registered course &amp; schedule are shown below.
</p>

<table border="1" cellpadding="8" style="margin:auto; border-collapse:collapse;">
    <tr>
        <th>Course Name</th>
        <th>Semester</th>
        <th>Session Time</th>
        <th>Days</th>
    </tr>

    @foreach (var course in Model)
    {
        <tr>
            <td>@course.CourseName</td>
            <td>@course.Semester</td>
            <td>@course.SessionTime</td>
            <td>@course.Days</td>
        </tr>
    }
</table>